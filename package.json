{
  "name": "@glw907/cairn-cms",
  "version": "0.82.1",
  "description": "Embedded, magic-link, GitHub-committing CMS for SvelteKit/Cloudflare sites.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "sideEffects": [
    "**/*.svelte",
    "**/*.css"
  ],
  "license": "MIT",
  "author": "Geoff Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glw907/cairn-cms.git"
  },
  "homepage": "https://github.com/glw907/cairn-cms#readme",
  "bugs": {
    "url": "https://github.com/glw907/cairn-cms/issues"
  },
  "keywords": [
    "cms",
    "sveltekit",
    "cloudflare",
    "github",
    "magic-link",
    "markdown"
  ],
  "scripts": {
    "package": "svelte-package && node scripts/build-admin-css.mjs && node scripts/transpile-dist-svelte.mjs && chmod +x dist/vite/bin.js dist/doctor/bin.js",
    "check:package": "npm run package && publint --strict && attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "check:reference": "npm run package && node scripts/reference-coverage.mjs",
    "check:reference:signatures": "npm run package && node scripts/check-reference-signatures.mjs",
    "check:surface": "npm run package && node scripts/check-surface.mjs",
    "check:readiness": "npm run package && node scripts/check-readiness.mjs",
    "check:docs": "node scripts/docs-links.mjs",
    "check:snippets": "npm run package && node scripts/check-snippets.mjs",
    "check:version": "node scripts/check-version.mjs",
    "check:prose": "node scripts/check-admin-prose.mjs",
    "check:public-tokens": "node scripts/check-public-tokens.mjs",
    "check:custom-surface": "npm run package && node scripts/check-custom-surface.mjs",
    "check:chassis-boundary": "node scripts/check-chassis-boundary.mjs",
    "check:cm-internals": "node scripts/check-cm-internals.mjs",
    "test:reskin": "node scripts/reskin-fixture.mjs",
    "lint": "eslint src/lib",
    "check:comments": "bash scripts/check-comments.sh",
    "check:dev-package": "node scripts/check-dev-package.mjs",
    "check:consumers": "npm run package && node scripts/check-consumers.mjs",
    "prepare": "npm run package",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:component": "vitest run --project component",
    "emit-template": "node scripts/emit-template.mjs",
    "test:emit": "node --test scripts/emit-template.test.mjs",
    "design:mockup-css": "npm run package && node scripts/build-mockup-css.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./sveltekit": {
      "types": "./dist/sveltekit/index.d.ts",
      "svelte": "./dist/sveltekit/index.js",
      "default": "./dist/sveltekit/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "svelte": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./admin-fields": {
      "types": "./dist/admin-fields/index.d.ts",
      "svelte": "./dist/admin-fields/index.js",
      "default": "./dist/admin-fields/index.js"
    },
    "./islands": {
      "types": "./dist/islands/index.d.ts",
      "default": "./dist/islands/index.js"
    },
    "./render": {
      "types": "./dist/render/authoring.d.ts",
      "svelte": "./dist/render/authoring.js",
      "default": "./dist/render/authoring.js"
    },
    "./delivery": {
      "types": "./dist/delivery/index.d.ts",
      "svelte": "./dist/delivery/index.js",
      "default": "./dist/delivery/index.js"
    },
    "./delivery/head": {
      "types": "./dist/delivery/head.d.ts",
      "svelte": "./dist/delivery/head.js",
      "default": "./dist/delivery/head.js"
    },
    "./delivery/data": {
      "types": "./dist/delivery/data.d.ts",
      "svelte": "./dist/delivery/data.js",
      "default": "./dist/delivery/data.js"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "svelte": "./dist/media/index.js",
      "default": "./dist/media/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    },
    "./ambient": {
      "types": "./dist/ambient.d.ts",
      "default": "./dist/ambient.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cairn-manifest": "./dist/vite/bin.js",
    "cairn-doctor": "./dist/doctor/bin.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@sveltejs/kit": "^2.12",
    "svelte": "^5.56.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lucide/svelte": "^1.17.0",
    "@rodrigodagostino/svelte-sortable-list": "^2.1.17",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "esm-env": "^1.2.2",
    "gray-matter": "^4",
    "hast-util-sanitize": "^5.0.2",
    "hast-util-to-string": "^3.0.1",
    "hastscript": "^9.0.1",
    "heic-to": "^1.5.2",
    "mdast-util-directive": "^3.1.0",
    "rehype-parse": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-remark": "^10.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "shiki": "^4.3.0",
    "spellchecker-wasm": "^0.3.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "yaml": "^2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@cloudflare/vitest-pool-workers": "^0.16",
    "@cloudflare/workers-types": "^4.20260501.0",
    "@sveltejs/kit": "^2.61",
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^7.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.19.19",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "culori": "^4.0.2",
    "daisyui": "^5.6.6",
    "devalue": "^5.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^63.0.7",
    "eslint-plugin-tsdoc": "^0.5.2",
    "lightningcss": "^1.32.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "postcss-prefix-selector": "^2.1.1",
    "publint": "^0.3.21",
    "svelte": "^5.56.3",
    "svelte-check": "^4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0",
    "vitest": "^4.1",
    "vitest-browser-svelte": "^2.1.1",
    "wrangler": "^4"
  }
}
