{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "outDir": "./dist"
  },
  "include": ["src/lib/**/*.ts", "src/lib/**/*.svelte", "src/tests/**/*.ts"],
  "exclude": ["examples", "dist", "node_modules"]
}
